# ---------------------------------------------------
# ENVIRONMENT
# ---------------------------------------------------

ENVIRONMENT=DEV

# ---------------------------------------------------
# AWS
# ---------------------------------------------------

AWS_REGION=us-east-1

# ---------------------------------------------------
# KAFKA
# ---------------------------------------------------

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

KAFKA_TOPIC=telemetry

# ---------------------------------------------------
# POSTGRES
# ---------------------------------------------------

POSTGRES_HOST=172.31.20.140
POSTGRES_PORT=5432
POSTGRES_DB=telemetry_db
POSTGRES_USER=farhan
POSTGRES_PASSWORD=Farhan@123

# ---------------------------------------------------
# S3
# ---------------------------------------------------

S3_GOLD_BUCKET=s3a://ttn-de-bootcamp-gold-us-east-1/farhan_gold

CHECKPOINT_DRIVER_SAFETY=s3://ttn-de-bootcamp-gold-us-east-1/farhan_gold/checkpoints/driver_safety/

CHECKPOINT_DRIVER_RISK=s3://ttn-de-bootcamp-gold-us-east-1/farhan_gold/checkpoints/driver_risk_aggregates/

CHECKPOINT_POSTGRES_STATE=s3://ttn-de-bootcamp-gold-us-east-1/farhan_gold/checkpoints/postgres_driver_state/

# ---------------------------------------------------
# STREAM SETTINGS
# ---------------------------------------------------

WATERMARK_DELAY=10 minutes

STREAM_TRIGGER=1 minute

MAX_OFFSETS_PER_TRIGGER=5000

SHUFFLE_PARTITIONS=4

# ---------------------------------------------------
# RISK THRESHOLDS
# ---------------------------------------------------

LOW_RISK_THRESHOLD=1

MEDIUM_RISK_THRESHOLD=3

HIGH_RISK_THRESHOLD=5

CRITICAL_RISK_THRESHOLD=25

SUSPENSION_THRESHOLD=15

WARNING_THRESHOLD=8

SUSPENSION_24H_THRESHOLD=15

SUSPENSION_7D_THRESHOLD=25

# ---------------------------------------------------
# BUSINESS RULES
# ---------------------------------------------------

OVERSPEED_LIMIT=110

RPM_LIMIT=4500

RATE_DEDUCTION_PERCENT=0.05

# ---------------------------------------------------
# RESTRICTED ZONE
# ---------------------------------------------------

RESTRICTED_ZONE_MIN_LAT=12.5
RESTRICTED_ZONE_MAX_LAT=12.8

RESTRICTED_ZONE_MIN_LON=77.2
RESTRICTED_ZONE_MAX_LON=77.5

# ---------------------------------------------------
# LOGGING
# ---------------------------------------------------

LOG_LEVEL=WARN

ENABLE_DEBUG=false